<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/studymate_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/studymate_purple">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/backBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back" />

                <TextView
                    android:id="@+id/profileTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Profile"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginEnd="48dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp"
            android:layout_marginTop="-40dp">

            <LinearLayout
                android:id="@+id/profileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/studymate_surface"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_profile"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:contentDescription="Profile Icon"
                            app:tint="@color/studymate_purple" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <TextView
                            android:id="@+id/studentName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Name"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/studymate_text_primary" />

                        <TextView
                            android:id="@+id/studentEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="student@example.com"
                            android:textSize="16sp"
                            android:textColor="@color/studymate_text_secondary"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/studymate_border"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:baselineAligned="false">

                    <!-- TODO load assignment count from Assignment database for logged-in user -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/assignmentsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/studymate_purple" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assignments"
                            android:textSize="14sp"
                            android:textColor="@color/studymate_text_secondary" />
                    </LinearLayout>

                    <!-- TODO load flashcard count from Flashcard database for logged-in user -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/flashcardsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/studymate_pink" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Flashcards"
                            android:textSize="14sp"
                            android:textColor="@color/studymate_text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- EMAIL SETTINGS -->
            <LinearLayout
                android:id="@+id/emailSettingsCard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@color/studymate_surface"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_purple">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/white"
                        android:contentDescription="Email Settings" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Email Settings"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/studymate_text_primary" />

                <ImageView
                    android:id="@+id/emailArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    android:rotation="270"
                    android:contentDescription="Expand Email Settings"
                    app:tint="@color/studymate_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/emailDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/studymate_surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter new email"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/studymate_text_primary"
                    android:textColorHint="@color/studymate_text_secondary"
                    android:backgroundTint="@color/studymate_purple"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/saveEmailBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Email"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/studymate_pink"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- NOTIFICATIONS -->
            <LinearLayout
                android:id="@+id/notificationsCard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@color/studymate_surface"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_pink">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/white"
                        android:contentDescription="Notifications" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notifications"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/studymate_text_primary" />

                <ImageView
                    android:id="@+id/notificationsArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    android:rotation="270"
                    android:contentDescription="Expand Notifications"
                    app:tint="@color/studymate_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notificationsDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/studymate_surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <Switch
                    android:id="@+id/pushNotificationSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Notifications"
                    android:textColor="@color/studymate_text_primary"
                    android:layout_marginBottom="8dp" />

                <Switch
                    android:id="@+id/reminderSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Assignment Reminders"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>

            <!-- PRIVACY -->
            <LinearLayout
                android:id="@+id/privacyCard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@color/studymate_surface"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_yellow">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/white"
                        android:contentDescription="Privacy &amp; Security" />
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Privacy &amp; Security"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/studymate_text_primary" />

                <ImageView
                    android:id="@+id/privacyArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    android:rotation="270"
                    android:contentDescription="Expand Privacy"
                    app:tint="@color/studymate_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/privacyDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/studymate_surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/privateProfileCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Private profile"
                    android:textColor="@color/studymate_text_primary" />

                <CheckBox
                    android:id="@+id/saveLoginCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep me signed in"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>

            <!-- LOGOUT -->
            <LinearLayout
                android:id="@+id/logoutCard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="@color/studymate_surface"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_pink">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_logout"
                        app:tint="@color/white"
                        android:contentDescription="Log Out" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log Out"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/studymate_pink" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>