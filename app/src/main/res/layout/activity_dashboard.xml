<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF6FB"
    android:padding="24dp">

    <TextView
        android:id="@+id/dashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="StudyMate"
        android:textColor="#7B3FF2"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dashboardSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Dashboard"
        android:textColor="#2B1B3B"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/subjectsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Subjects"
        android:backgroundTint="#7B3FF2"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/assignmentsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Assignments"
        android:backgroundTint="#F5429E"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/flashcardsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Flashcards"
        android:backgroundTint="#FFC83D"
        android:textColor="#2B1B3B" />

</LinearLayout>