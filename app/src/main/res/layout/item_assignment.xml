<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="@color/studymate_surface"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@color/studymate_background"
        android:layout_marginEnd="16dp">

        <ImageView
            android:id="@+id/assignmentIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="Assignment Icon" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/assignmentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile Dev Coursework"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/studymate_text_primary" />

        <TextView
            android:id="@+id/assignmentDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due: May 20, 2024"
            android:textSize="16sp"
            android:textColor="@color/studymate_text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/assignmentArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textSize="28sp"
        android:textColor="@color/studymate_text_secondary" />

</LinearLayout>