<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/studymate_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp"
            android:background="@color/studymate_purple">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back"
                app:tint="@android:color/white"/>

            <TextView
                android:id="@+id/calendarTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/calendar_title"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/homeBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/home"
                app:tint="@android:color/white"/>
        </LinearLayout>

        <!-- Month navigation card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:background="@color/studymate_surface"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Previous -->
            <ImageButton
                android:id="@+id/previousMonthBtn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_circle_pink"
                android:src="@drawable/ic_chevron_left"
                android:contentDescription="@string/previous_month"
                android:padding="10dp"
                app:tint="@android:color/white" />

            <!-- Month label -->
            <TextView
                android:id="@+id/monthLabelText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="April 2026"
                android:textColor="@color/studymate_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Next -->
            <ImageButton
                android:id="@+id/nextMonthBtn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_circle_pink"
                android:src="@drawable/ic_chevron_right"
                android:contentDescription="@string/next_month"
                android:padding="10dp"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- Calendar grid card -->
        <LinearLayout
            android:id="@+id/calendarRowsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:background="@color/studymate_surface"
            android:orientation="vertical"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>