<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/userSettingsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_settings_button" />

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/welcome_back_placeholder"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/next_due_countdown_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nextDueCountdownText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/no_due_assignments"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nextDueDetailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/next_due_details_placeholder" />

        <Button
            android:id="@+id/assignmentsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="72dp"
            android:text="@string/assignments_button" />

        <Button
            android:id="@+id/flashcardsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="72dp"
            android:text="@string/flashcards_button" />

        <Button
            android:id="@+id/subjectsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="72dp"
            android:text="@string/subjects_button" />

        <Button
            android:id="@+id/calendarBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="72dp"
            android:text="@string/calendar_button" />


        <Button
            android:id="@+id/statisticsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="72dp"
            android:text="@string/statistics_button" />

        <!-- Disabled for now: this testing-only ClearAllData button used to wipe every table. -->
        <!-- It is commented out so it stays in the file and can be re-enabled later. -->
        <!--
        <Button
            android:id="@+id/clearDataBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Clear all saved data" />
        -->

    </LinearLayout>
</ScrollView>

