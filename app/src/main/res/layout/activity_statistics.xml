<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/studymate_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:padding="20dp"
            android:background="@color/studymate_purple"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back" />

            <TextView
                android:id="@+id/statisticsTitleText"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/statistics_title"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/homeBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/home"
                android:src="@drawable/ic_home" />
        </LinearLayout>

        <!-- Metrics Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/summary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <!-- Metric Cards Row 1 -->
        <LinearLayout
            android:id="@+id/metricsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/metricCard1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/studymate_yellow">

                <TextView
                    android:id="@+id/metricValue1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/metricLabel1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flashcards_complete"
                    android:paddingTop="8dp"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/metricCard2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/studymate_pink">

                <TextView
                    android:id="@+id/metricValue2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/metricLabel2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/assignments_complete"
                    android:paddingTop="8dp"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Metric Cards Row 2 -->
        <LinearLayout
            android:id="@+id/metricsContainer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/metricCard3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/studymate_purple">

                <TextView
                    android:id="@+id/metricValue3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/metricLabel3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_streak"
                    android:paddingTop="8dp"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/metricCard4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/studymate_blue">

                <TextView
                    android:id="@+id/metricValue4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/metricLabel4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cards_studied"
                    android:paddingTop="8dp"
                    android:textColor="@color/studymate_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Subject Progress Section Title -->
        <TextView
            android:id="@+id/progressTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subject_progress_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp" />

        <!-- Container for subject progress rows (inflate subject_progress_row.xml dynamically) -->
        <LinearLayout
            android:id="@+id/subjectProgressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">
        </LinearLayout>

    </LinearLayout>
</ScrollView>