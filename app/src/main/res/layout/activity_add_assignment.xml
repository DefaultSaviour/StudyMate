<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/studymate_background"
    android:padding="0dp">

    <!-- Single parent LinearLayout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp"
            android:background="@color/studymate_purple">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back" />

            <!-- Screen title centered -->
            <TextView
                android:id="@+id/screenTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/add_assignment"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Home button -->
            <ImageButton
                android:id="@+id/homeBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/home"
                android:src="@drawable/ic_home" />
        </LinearLayout>

        <!-- Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/studymate_text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/assignmentTitleInput"
                android:layout_width="357dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:autofillHints="username"
                android:backgroundTint="@color/studymate_purple"
                android:hint="@string/title_hint"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/studymate_text_primary"
                android:textColorHint="@color/studymate_text_secondary" />

            <!-- Subject spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subject_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/studymate_text_primary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/subjectSpinner"
                android:layout_width="357dp"
                android:layout_height="51dp"
                android:layout_marginBottom="24dp" />

            <!-- Due date input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/due_date_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/studymate_text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/dueDateValueText"
                android:layout_width="357dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:autofillHints="date"
                android:backgroundTint="@color/studymate_purple"
                android:clickable="true"
                android:focusable="false"
                android:hint="@string/due_date_hint"
                android:inputType="date|time"
                android:padding="12dp"
                android:textColor="@color/studymate_text_primary"
                android:textColorHint="@color/studymate_text_secondary" />

            <Button
                android:id="@+id/pickDueDateBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_due_date"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:padding="14dp"
                android:backgroundTint="@color/studymate_purple"
                android:layout_marginBottom="24dp"
                android:layout_gravity="center_horizontal"
                android:minWidth="200dp" />

            <!-- Icon selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_label"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/studymate_text_primary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/iconOptionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp" />

            <!-- Save button -->
            <Button
                android:id="@+id/saveAssignmentBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save_assignment"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:padding="14dp"
                android:backgroundTint="@color/studymate_pink"
                android:layout_gravity="center_horizontal"
                android:minWidth="200dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>